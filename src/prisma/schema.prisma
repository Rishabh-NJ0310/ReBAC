// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String

  relationships Relationship[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Resource {
  id        Int      @id @default(autoincrement())
  type      String
  name      String

  relationshipsAsSubject Relationship[] @relation("SubjectResource")
  relationshipsAsTarget  Relationship[] @relation("TargetResource")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Relationship {
  id Int @id @default(autoincrement())

  relation String

  userSubjectId Int?
  userSubject   User? @relation(fields: [userSubjectId], references: [id])

  resourceSubjectId Int?
  resourceSubject   Resource? @relation("SubjectResource", fields: [resourceSubjectId], references: [id])

  objectId Int
  object   Resource @relation("TargetResource", fields: [objectId], references: [id])

  createdAt DateTime @default(now())

  @@index([objectId, relation])
}