// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Subject Type Enum ────────────────────────────────────────────────────────

enum SubjectType {
  USER
  GROUP
  ROLE
  TEAM
  SERVICE_ACCOUNT
}

// ─── Identity Nodes ───────────────────────────────────────────────────────────

// Every entity that can HOLD a permission is a Subject.
// User and Group are concrete identity types backed by their own tables.
model Subject {
  id   Int         @id @default(autoincrement())
  type SubjectType
  name String

  // Concrete identity — at most one of these is set
  user  User?
  group Group?

  // Identity Graph edges (Subject → Subject)
  outgoingSubjectEdges SubjectEdge[] @relation("SubjectEdgeSource")
  incomingSubjectEdges SubjectEdge[] @relation("SubjectEdgeTarget")

  // Permission Graph edges (Subject → Resource)
  permissionEdges PermissionEdge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("SubjectV3")
}

model User {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  password String

  // Every User is backed by exactly one Subject
  subjectId Int     @unique
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("UserV3")
}

model Group {
  id   Int    @id @default(autoincrement())
  name String

  // Every Group is backed by exactly one Subject
  subjectId Int     @unique
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("GroupV3")
}

// ─── Resource Node ────────────────────────────────────────────────────────────

model Resource {
  id   Int    @id @default(autoincrement())
  type String
  name String

  // Resource Graph edges (Resource → Resource)
  outgoingResourceEdges ResourceEdge[] @relation("ResourceEdgeSource")
  incomingResourceEdges ResourceEdge[] @relation("ResourceEdgeTarget")

  // Permission Graph edges (Subject → Resource)
  permissionEdges PermissionEdge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ResourceV3")
}

// ─── Graph 1: Identity Graph  (Subject ──[member/owner/manager]──> Subject) ──

// Raj ──member──> Doctors
// Doctors ──member──> MedicalStaff
model SubjectEdge {
  id       Int    @id @default(autoincrement())
  relation String // "member", "owner", "manager"

  sourceId Int
  source   Subject @relation("SubjectEdgeSource", fields: [sourceId], references: [id], onDelete: Cascade)

  targetId Int
  target   Subject @relation("SubjectEdgeTarget", fields: [targetId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([sourceId, targetId, relation])
  @@index([sourceId, relation])
  @@index([targetId, relation])
  @@map("SubjectEdgeV3")
}

// ─── Graph 2: Resource Graph  (Resource ──[contains]──> Resource) ────────────

// Department ──contains──> Ward
// Ward ──contains──> Patient
model ResourceEdge {
  id       Int    @id @default(autoincrement())
  relation String // "contains", "parent", "part_of"

  sourceId Int
  source   Resource @relation("ResourceEdgeSource", fields: [sourceId], references: [id], onDelete: Cascade)

  targetId Int
  target   Resource @relation("ResourceEdgeTarget", fields: [targetId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([sourceId, targetId, relation])
  @@index([sourceId, relation])
  @@index([targetId, relation])
  @@map("ResourceEdgeV3")
}

// ─── Graph 3: Permission Graph  (Subject ──[doctor_of/viewer]──> Resource) ───

// Doctors ──doctor_of──> Patient101
// Raj ──assigned_nurse──> Ward-ICU
model PermissionEdge {
  id       Int    @id @default(autoincrement())
  relation String // "doctor_of", "assigned_nurse", "viewer", "editor"

  subjectId Int
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  resourceId Int
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([subjectId, resourceId, relation])
  @@index([subjectId, relation])
  @@index([resourceId, relation])
  @@map("PermissionEdgeV3")
}