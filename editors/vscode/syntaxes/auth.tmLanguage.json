{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Authorization DSL",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#resource-decl"
    },
    {
      "include": "#relation-decl"
    },
    {
      "include": "#permission-decl"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.auth",
          "match": "#.*$"
        },
        {
          "name": "comment.line.double-slash.auth",
          "match": "//.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.auth",
          "match": "\\b(resource|relation|permission)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.logical.auth",
          "match": "\\b(AND|OR|NOT)\\b"
        },
        {
          "name": "keyword.operator.arrow.auth",
          "match": "->"
        },
        {
          "name": "keyword.operator.assignment.auth",
          "match": "="
        }
      ]
    },
    "resource-decl": {
      "match": "\\b(resource)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": {
          "name": "keyword.control.auth"
        },
        "2": {
          "name": "entity.name.type.class.auth"
        }
      }
    },
    "relation-decl": {
      "match": "\\b(relation)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": {
          "name": "keyword.control.auth"
        },
        "2": {
          "name": "variable.other.property.auth"
        }
      }
    },
    "permission-decl": {
      "match": "\\b(permission)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": {
          "name": "keyword.control.auth"
        },
        "2": {
          "name": "entity.name.function.auth"
        }
      }
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.section.curly.auth",
          "match": "[{}]"
        },
        {
          "name": "punctuation.section.parens.auth",
          "match": "[()]"
        }
      ]
    }
  },
  "scopeName": "source.auth"
}